{
  "name": "Anna's Archive",
  "searchBaseUrl": "https://annas-archive.li",
  "storyBaseUrl": "https://annas-archive.li",
  "type": "debrid_document",
  "search": {
    "url": "/search?q={query}&ext=epub&lang=en&sort=newest",
    "listSelector": "a[href^=\"/md5/\"]",
    "titleSelector": "h3",
    "linkSelector": "",
    "authorSelector": "div.italic",
    "coverSelector": "img"
  },
  "resolver": {
    "selector": "a[href*=\"torrent\"], a[href^=\"magnet:\"]",
    "attribute": "href"
  }
}
