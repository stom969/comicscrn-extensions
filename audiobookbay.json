{
  "id": "audiobookbay",
  "name": "AudioBookBay",
  "version": "1.0.1",
  "type": "debrid_audiobook",
  "searchBaseUrl": "https://audiobookbay.lu",
  "search": {
    "url": "/page/{page}/?s={query}",
    "listSelector": "div.post",
    "titleSelector": ".postTitle h2 a",
    "linkSelector": ".postTitle h2 a",
    "headers": {
      "User-Agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36"
    }
  }
}
